# URL to download (YouTube or VK Video): playlist or single video
DOWNLOAD_URL=https://www.youtube.com/playlist?list=PLpxZhOxCdp9G8TcJaRN_oNIeQc96uoM61

# Video resolution (360p or 720p)
VIDEO_RESOLUTION=720p

# ===== transcribe.py settings (keep together) =====
# Folder containing .mp4 files to process
TRANSCRIBE_VIDEO_FOLDER=path\to\your\folder\with\videos

# Whisper source language code (examples: en, fr, ru)
TRANSCRIBE_WHISPER_LANGUAGE=en

# Translation direction for subtitles
TRANSCRIBE_TRANSLATION_SOURCE_LANGUAGE=en
TRANSCRIBE_TRANSLATION_TARGET_LANGUAGE=ru

# Optional explicit model name override (if empty, model is auto-picked from source/target pair)
# Example for French -> English: Helsinki-NLP/opus-mt-fr-en
TRANSCRIBE_TRANSLATION_MODEL=

# Enable phonetic line in subtitles: true/false
# English respelling is supported only when source language is English
TRANSCRIBE_ENABLE_PHONETIC=true
TRANSCRIBE_PHONETIC_LANGUAGE=en

# Encoding for the translated sidecar SRT copied next to the video
# Common values: utf-8, windows-1251, cp1252
TRANSCRIBE_SIDECAR_SRT_ENCODING=utf-8

# Hugging Face token for model downloads/rate limits (optional)
TRANSCRIBE_HF_TOKEN=your_huggingface_token_here

# Force local-only model loading (set true only when models are pre-cached)
TRANSCRIBE_OFFLINE_MODE=false

# Destination folder for completed outputs (optional)
TRANSCRIBE_OUTPUT_FOLDER=
# ===== end transcribe.py settings =====

# ===== subtitles_to_markdown.py settings =====
# Folder containing subtitle files (searched recursively)
TRANSCRIBE_SUBTITLE_SOURCE_DIR=

# Output Markdown file path
TRANSCRIBE_SUBTITLE_OUTPUT_MD=

# File mask for subtitle files (optional)
TRANSCRIBE_SUBTITLE_GLOB=*.srt

# Encoding of source subtitle files (optional)
# Defaults to TRANSCRIBE_SIDECAR_SRT_ENCODING (or legacy names)
TRANSCRIBE_SUBTITLE_SOURCE_ENCODING=

# Comma-separated fallback encodings for mixed subtitle sources (optional)
TRANSCRIBE_SUBTITLE_SOURCE_ENCODING_FALLBACKS=utf-8,utf-8-sig,windows-1251,cp1251

# Encoding for merged markdown output (optional)
# Defaults to TRANSCRIBE_SIDECAR_SRT_ENCODING (or legacy names)
TRANSCRIBE_SUBTITLE_OUTPUT_ENCODING=
# ===== end subtitles_to_markdown.py settings =====

# Legacy transcribe.py variables (optional backward compatibility)
# VIDEO_FOLDER=
# LANGUAGE=
# TRANSCRIBE_DUPLICATE_SRT_ENCODING=
# DUPLICATE_SRT_ENCODING=
# HF_TOKEN=
# OUTPUT_FOLDER=

PYTHONUNBUFFERED=1
