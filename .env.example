# URL to download (YouTube or VK Video): playlist or single video
DOWNLOAD_URL=https://www.youtube.com/playlist?list=PLpxZhOxCdp9G8TcJaRN_oNIeQc96uoM61

# Video resolution (360p or 720p)
VIDEO_RESOLUTION=720p

# ===== transcribe.py settings (keep together) =====
# Folder containing .mp4 files to process
TRANSCRIBE_VIDEO_FOLDER=path\to\your\folder\with\videos

# Whisper source language code (examples: en, fr, ru)
TRANSCRIBE_WHISPER_LANGUAGE=en

# Translation direction for subtitles
TRANSCRIBE_TRANSLATION_SOURCE_LANGUAGE=en
TRANSCRIBE_TRANSLATION_TARGET_LANGUAGE=ru

# Optional explicit model name override (if empty, model is auto-picked from source/target pair)
# Example for French -> English: Helsinki-NLP/opus-mt-fr-en
TRANSCRIBE_TRANSLATION_MODEL=

# Enable phonetic line in subtitles: true/false
# English respelling is supported only when source language is English
TRANSCRIBE_ENABLE_PHONETIC=true
TRANSCRIBE_PHONETIC_LANGUAGE=en

# Encoding for the translated sidecar SRT copied next to the video
# Common values: utf-8, windows-1251, cp1252
TRANSCRIBE_SIDECAR_SRT_ENCODING=utf-8

# Speech span detection and usage
TRANSCRIBE_ENABLE_SPEECH_SPANS=true
TRANSCRIBE_SPEECH_SPANS_DETECT_IF_MISSING=true
TRANSCRIBE_SPEECH_SPANS_OVERWRITE=false
TRANSCRIBE_USE_SPEECH_SPANS_FOR_WHISPER=true
TRANSCRIBE_FILTER_SIDECAR_SRT_BY_SPEECH_SPANS=true
TRANSCRIBE_SPEECH_SPANS_ONLY_MODE=false
TRANSCRIBE_TRANSLATION_ONLY_MODE=false
TRANSCRIBE_TRANSLATION_INPUT=original
TRANSCRIBE_TRANSLATION_OVERWRITE=false
TRANSCRIBE_TRANSLATION_APPEND_SOURCE=true
TRANSCRIBE_UPDATE_SIDECAR_FROM_TRANSLATION=false
TRANSCRIBE_SPEECH_SPAN_MARGIN_SEC=0.35
TRANSCRIBE_SPEECH_VAD_THRESHOLD=0.3
TRANSCRIBE_SPEECH_MIN_DURATION_SEC=0.15
TRANSCRIBE_SPEECH_MIN_SILENCE_SEC=0.2
TRANSCRIBE_SPEECH_SPAN_FILE_SUFFIX=.speech_spans.json
TRANSCRIBE_SPEECH_FILTER_RESCUE_DENSE_RUNS=true
TRANSCRIBE_SPEECH_FILTER_RESCUE_MIN_CUES=4
TRANSCRIBE_SPEECH_FILTER_RESCUE_MIN_DURATION_SEC=8
TRANSCRIBE_SPEECH_FILTER_RESCUE_MAX_DURATION_SEC=90
TRANSCRIBE_SPEECH_FILTER_RESCUE_MIN_DENSITY=0.08
TRANSCRIBE_SPEECH_FILTER_RESCUE_TINY_RUNS=true
TRANSCRIBE_SPEECH_FILTER_RESCUE_TINY_MAX_CUES=3
TRANSCRIBE_SPEECH_FILTER_RESCUE_TINY_MAX_DURATION_SEC=4
TRANSCRIBE_SPEECH_FILTER_RESCUE_TINY_NEIGHBOR_GAP_SEC=8
TRANSCRIBE_SPEECH_FILTER_RESCUE_BRIDGE_RUNS=true
TRANSCRIBE_SPEECH_FILTER_RESCUE_BRIDGE_MAX_CUES=6
TRANSCRIBE_SPEECH_FILTER_RESCUE_BRIDGE_MAX_DURATION_SEC=25

# Master pipeline step flags (used by main.py)
# Set TRANSCRIBE_INTERACTIVE=true to choose profile/features in terminal UI.
TRANSCRIBE_INTERACTIVE=true
TRANSCRIBE_RUN_GENERATE_SPANS=false
TRANSCRIBE_RUN_FILTER_SIDECARS=false
TRANSCRIBE_RUN_TRANSCRIPTION=false
TRANSCRIBE_RUN_TRANSLATION=false
TRANSCRIBE_RUN_BAKE_SUBTITLES=false
TRANSCRIBE_RUN_SIDECAR_REPLACE=false
TRANSCRIBE_RUN_MERGE=false

# Master pipeline force flags
TRANSCRIBE_FORCE_SPANS=true
TRANSCRIBE_FORCE_TRANSCRIPTION=false
TRANSCRIBE_FORCE_TRANSLATION=true
TRANSCRIBE_FORCE_BAKE_SUBTITLES=false

# Bake subtitles into video (hardcoded/burned-in)
TRANSCRIBE_ENABLE_BAKED_SUBTITLES=false
TRANSCRIBE_BAKE_SUBTITLES_ONLY_MODE=false
TRANSCRIBE_BAKE_SUBTITLES_OVERWRITE=false

# Optional single video name/stem for focused runs
TRANSCRIBE_SINGLE_VIDEO=

# Hugging Face token for model downloads/rate limits (optional)
TRANSCRIBE_HF_TOKEN=your_huggingface_token_here

# Force local-only model loading (set true only when models are pre-cached)
TRANSCRIBE_OFFLINE_MODE=false

# Destination folder for completed outputs (optional)
TRANSCRIBE_OUTPUT_FOLDER=
# ===== end transcribe.py settings =====

# ===== subtitles_to_markdown.py settings =====
# Folder containing subtitle files (searched recursively)
TRANSCRIBE_SUBTITLE_SOURCE_DIR=

# Output Markdown file path
TRANSCRIBE_SUBTITLE_OUTPUT_MD=

# File mask for subtitle files (optional)
TRANSCRIBE_SUBTITLE_GLOB=*.srt

# Encoding of source subtitle files (optional)
# Defaults to TRANSCRIBE_SIDECAR_SRT_ENCODING (or legacy names)
TRANSCRIBE_SUBTITLE_SOURCE_ENCODING=

# Comma-separated fallback encodings for mixed subtitle sources (optional)
TRANSCRIBE_SUBTITLE_SOURCE_ENCODING_FALLBACKS=utf-8,utf-8-sig,windows-1251,cp1251

# Encoding for merged markdown output (optional)
# Defaults to TRANSCRIBE_SIDECAR_SRT_ENCODING (or legacy names)
TRANSCRIBE_SUBTITLE_OUTPUT_ENCODING=
# ===== end subtitles_to_markdown.py settings =====

PYTHONUNBUFFERED=1
