# Language for phonetic transcription
# 'en' - English phonetic respelling with syllables and stress markers
# other - Simple phonetic transcription
LANGUAGE=en

# YouTube playlist URL to download
PLAYLIST_URL=https://www.youtube.com/watch?v=-0r9VzzXk3I&list=PLpxZhOxCdp9G8TcJaRN_oNIeQc96uoM61

# Video resolution (360p or 720p)
VIDEO_RESOLUTION=720p

# Folder containing video files to process
VIDEO_FOLDER=path\to\your\folder\with\videos

# Encoding for the duplicate translated SRT file in the video folder
# Common values: 'utf-8', 'windows-1251', 'cp1252', etc.
DUPLICATE_SRT_ENCODING=utf-8

# Hugging Face token for faster model downloads and higher rate limits
# Get your token from https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Output folder for fully processed videos (optional)
# If set, videos will be moved here after complete processing
OUTPUT_FOLDER=

PYTHONUNBUFFERED=1